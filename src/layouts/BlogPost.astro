---
import BaseHead from "../components/BaseHead.astro";
import JsonLd from "../components/JsonLd.astro";
import MainLayout from "./MainLayout.astro";
import Block from "../components/common/Block.astro";
import ThemeSwitcher from "../components/ThemeSwitcher/ThemeSwitcher.astro";
import InfoCardBlogPost from "../components/InfoCardContent/Blog.astro";
import Badge from "../components/common/Badge.astro";
import Button from "../components/common/LinkButton.astro";
import { blogPostingSchema } from "../lib/schema";

const { title, description, pubDate, updatedDate, tags = [], heroImage, slug } = Astro.props;
const isGeneratedCard = !heroImage;
const ogImage = heroImage ?? (slug ? `/og/blog/${slug}.png` : "/og/default.png");
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const absoluteImage = new URL(ogImage, Astro.site ?? Astro.url).toString();
const articleSchema = blogPostingSchema({
	title,
	description,
	url: pageUrl,
	image: absoluteImage,
	pubDate: new Date(pubDate),
	updatedDate: updatedDate ? new Date(updatedDate) : undefined,
	tags,
});

const tagsToString = tags.length > 0 ? tags.join(", ") : "BLOG";
const pubDateObj = new Date(pubDate);
const pubDateOptions: Intl.DateTimeFormatOptions = {
	year: "numeric",
	month: "long",
	day: "numeric",
};
const pubDateFormatted = pubDateObj.toLocaleDateString("en-US", pubDateOptions);
---

<BaseHead
	title={title}
	description={description}
	image={ogImage}
	imageWidth={isGeneratedCard ? 1200 : undefined}
	imageHeight={isGeneratedCard ? 630 : undefined}
	type="article"
	pubDate={new Date(pubDate)}
	updatedDate={updatedDate ? new Date(updatedDate) : undefined}
	tags={tags}
/>
<JsonLd schema={articleSchema} />

<MainLayout>
	<div slot="main">
		<Block>
			<div class="article-header">
				<Button text="← Back to Blog" href="/blog" variant="link" />
				<Badge text={tagsToString} />
			</div>
			<div class="article-meta">
				<span class="article-date">
					{pubDateFormatted}
				</span>
			</div>
			<h1 class="article-title">{title}</h1>
			<div class="article-content">
				<slot></slot>
			</div>
		</Block>
	</div>
	<ThemeSwitcher slot="theme" />
	<InfoCardBlogPost slot="latest" />
</MainLayout>

<style>
	.article-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1.5rem;
	}
	.article-meta {
		margin-bottom: 0.5rem;
	}
	.article-date {
		color: var(--text-blog-date);
		font-size: 1rem;
		font-family: var(--ff-heading);
		letter-spacing: 0.04em;
	}
	.article-title {
		font-family: var(--ff-heading);
		font-size: 2.7rem;
		font-weight: 700;
		margin: 0 0 2rem 0;
		color: var(--text-color);
		line-height: 1.1;
		word-break: break-word;
	}
	.article-content {
		color: var(--text-main);
		font-size: 1.18rem;
		line-height: 1.7;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-bottom: 100px;
	}
	.article-content code,
	.article-content pre {
		font-family: "JetBrains Mono", monospace;
		background: #f5f5f5;
		color: #222;
		border-radius: 0.5em;
		padding: 0.2em 0.5em;
		font-size: 1em;
	}
	.article-content pre {
		padding: 1em;
		overflow-x: auto;
		background: #ededed;
		margin: 1.5em 0;
	}
	.sidebar-title {
		font-size: 1.3rem;
		color: var(--text-high-contrast);
		margin-bottom: 1rem;
	}
	.blog-read-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		font-family: var(--ff-heading);
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text-high-contrast);
		background: var(--blog-btn-bg, transparent);
		border: 2px solid var(--text-high-contrast);
		border-radius: 0.5em;
		padding: 0.4em 1.5em;
		text-decoration: none;
		transition: background 0.2s, color 0.2s, border-color 0.2s;
		margin-top: 1.5rem;
	}
	.blog-read-btn:hover {
		background: var(--accent);
		color: #fff;
		border-color: var(--accent);
	}
	.arrow {
		font-size: 1.2em;
	}
	:global(.article-content a) {
		color: inherit;
		text-decoration: underline;
		text-underline-offset: 2px;
		cursor: pointer;
		transition: color 0.15s ease;
	}
	:global(.article-content a:hover),
	:global(.article-content a:focus-visible) {
		color: var(--badge-background);
	}
	:global(.article-content img) {
		display: block;
		max-width: 100%;
		height: auto;
		border-radius: var(--radii-10);
		margin: 0 auto;
	}
	:global(.article-content .post-hero) {
		max-width: 100%;
	}
	:global(.article-content .post-figure) {
		max-width: 480px;
		margin: 0 auto;
	}
	:global(.article-content .post-figure-sm) {
		max-width: 360px;
		margin: 0 auto;
	}
	@media (max-width: 900px) {
		.article-title {
			font-size: 1.5rem;
		}
		.article-content {
			font-size: 1rem;
		}
	}
</style>
